# Plaid Credentials
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_secret
PLAID_ACCESS_TOKEN=access-sandbox-xxxxxxxxxx

# Ollama Model Configurations (e.g. mistral, tinyllama)
OLLAMA_MODEL=tinyllama

# Alert Notification Credentials (email)
ALERT_EMAIL=your@email.com
SMTP_HOST=smtp.gmail.com
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password

# Default EMI Parameter settings
DEFAULT_EMI_AMOUNT=15000

# Immediate scheduler testing options
RUN_ON_START=false
